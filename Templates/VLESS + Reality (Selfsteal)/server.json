{
      "tag": "VLESS_INBOUND",
      "port": 443, // Recommended to use 443
      "protocol": "vless",
      "settings": {
        "flow": "xtls-rprx-vision",
        "clients": [],
        "decryption": "none"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "xver": 1,
          "target": "/dev/shm/nginx.sock",
          "shortIds": [
            ""
          ],
          "privateKey": "<generate with xray x25519>",
          "fingerprint": "randomized", // "randomized" or "firefox"
          "serverNames": [
            "yourdomain.com" // Replace with your domain
          ]
        }
      }
    },